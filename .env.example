# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Scraping Configuration
CACHE_TTL_MS=300000
MAX_RETRIES=3
RETRY_DELAY_MS=2000
REQUEST_TIMEOUT_MS=15000
SESSION_ROTATE_INTERVAL_MS=300000
ENABLE_STEALTH=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Shopee
SHOPEE_BASE_URL=https://shopee.tw

# Proxy (optional, comma-separated list)
# Format: http://user:pass@host:port or http://host:port
# PROXY_LIST=http://proxy1:8080,http://proxy2:8080
PROXY_LIST=

# ScraperAPI configuration (recommended for Shopee Taiwan)
# Free trial: 5,000 API calls at https://www.scraperapi.com/signup
# SCRAPERAPI_KEY=your_api_key
SCRAPERAPI_KEY=
SCRAPERAPI_COUNTRY_CODE=tw
SCRAPERAPI_PREMIUM=true
SCRAPERAPI_ULTRA_PREMIUM=false
SCRAPERAPI_RENDER=false
